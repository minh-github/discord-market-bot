BOT_TOKEN=your_discord_bot_token
CLIENT_ID=your_application_client_id
GUILD_ID=your_test_server_id
CHANNEL_ID=channel_id_to_post_daily_update

# Cron chạy lúc 08:00 sáng mỗi ngày
CRON_SCHEDULE=0 8 * * *

# Tùy chọn: nếu có CoinGecko Pro key thì thêm vào
COINGECKO_API_KEY=

# Vàng SJC: dùng API vang.today (không cần key)
# https://www.vang.today/api/prices?type=SJ9999&days=N

# VN-Index connector
# Bạn trỏ vào 1 API JSON bất kỳ trả về chỉ số hiện tại.
# Bot sẽ tự thử đọc các key như: value, price, last, vnindex...
VNINDEX_API_URL=
VNINDEX_API_HEADER_NAME=
VNINDEX_API_HEADER_VALUE=